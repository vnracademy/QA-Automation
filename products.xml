<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite" parallel="true" thread-count="5">

<groups>

	<run>
		<include name="products"/>
	</run>

</groups>

<listeners>

<listener class-name="vnracademy.testcomponents.Listeners"></listener>

</listeners>

  <test name="Add Products To Cart">
    <classes>
      	<class name="VNRACADEMY.opencart.AddProductsToCartTest"/>
    </classes>
  </test>
    
  <test name="Login To OpenCart">
    <classes>
    	<class name="VNRACADEMY.opencart.LoginToApplicationTest"/>
      	<class name="VNRACADEMY.opencart.ErrorValidationTest"/>
    </classes>
  </test> <!-- Test -->
</suite> <!-- Suite -->
